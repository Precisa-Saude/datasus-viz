{
  "name": "@precisa-saude/datasus-cli",
  "version": "1.3.1",
  "description": "CLI para microdados DATASUS — download, decodificação e agregação com saída JSON/JSONL",
  "keywords": [
    "datasus",
    "cli",
    "cnes",
    "sus",
    "microdados",
    "brasil",
    "saúde"
  ],
  "homepage": "https://github.com/Precisa-Saude/datasus-viz/tree/main/packages/cli#readme",
  "bugs": "https://github.com/Precisa-Saude/datasus-viz/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/datasus-viz.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "datasus-brasil": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsx src/index.ts",
