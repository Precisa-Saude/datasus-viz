    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@precisa-saude/datasus-sdk": "^2.0.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
