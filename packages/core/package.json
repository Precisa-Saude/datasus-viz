{
  "name": "@precisa-saude/datasus",
  "version": "1.0.0",
  "description": "Toolkit alto-nível para microdados DATASUS — FTP cliente, schemas tipados, labeling (IBGE, TP_UNID) e agregações",
  "keywords": [
    "datasus",
    "cnes",
    "sus",
    "microdados",
    "brasil",
    "saúde"
  ],
  "homepage": "https://github.com/Precisa-Saude/datasus-brasil/tree/main/packages/core#readme",
  "bugs": "https://github.com/Precisa-Saude/datasus-brasil/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/datasus-brasil.git",
    "directory": "packages/core"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "data",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:ans-mapping": "tsx scripts/extract-ans-xlsx.ts",
    "build:sigtap-mapping": "tsx scripts/build-sigtap-mapping.ts",
    "clean": "rm -rf dist .turbo",
    "fix:fhir-brasil-tuss": "tsx scripts/fix-fhir-brasil-tuss.ts",
    "lint": "eslint src/ --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@precisa-saude/datasus-dbc": "workspace:*",
    "basic-ftp": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
